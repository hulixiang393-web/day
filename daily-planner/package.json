{
  "name": "anime-planner",
  "version": "1.0.0",
  "description": "二次元跨端计划表",
  "main": "electron-main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "npx @electron/packager . \"二次元计划表\" --platform=win32 --arch=x64 --out=dist --overwrite --ignore=\"node_modules\"",
    "build:android": "npm run cap:sync && cd android && gradlew assembleDebug",
    "build:all": "npm run build:win && npm run build:android",
    "cap:init": "npx cap init \"二次元计划表\" com.anime.planner --web-dir=www",
    "cap:add": "npx cap add android",
    "cap:sync": "npx cap sync android",
    "cap:open": "npx cap open android",
    "www:sync": "node -e \"const{execSync}=require('child_process');execSync('rm -rf www && mkdir www && cp index.html www/ && cp manifest.json www/ && cp sw.js www/ && cp -r css www/ && cp -r js www/ && cp -r assets www/',{stdio:'inherit'})\""
  },
  "author": "hulixiang",
  "license": "MIT",
  "build": {
    "appId": "com.anime.planner",
    "productName": "二次元计划表",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": null,
      "sign": null,
      "signingHashAlgorithms": null,
      "certificateFile": null,
      "certificatePassword": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "二次元计划表"
    },
    "files": [
      "**/*",
      "!node_modules/**/*",
      "!dist/**/*"
    ],
    "extraResources": []
  },
  "devDependencies": {
    "@capacitor/android": "^8.4.2",
    "@capacitor/cli": "^8.4.2",
    "@capacitor/core": "^8.4.2",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8"
  }
}
